# .gitignore - Comprehensive Python + IDE ignores

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# uv
.uv/
uv.lock

# ============================================================================
# Testing & Coverage
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover

# ============================================================================
# IDEs & Editors
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db
*.bak
*.tmp
*.temp

# ============================================================================
# Build & Distribution
# ============================================================================
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ============================================================================
# Misc
# ============================================================================
.env
.env.local
*.log
.cache/
*.zip
